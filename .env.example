# RecoilLab — пример переменных окружения.
# Скопировать в .env и заполнить.
#
# .env находится в .gitignore — реальные секреты в репо не попадают.
#
# === DEV (локальная разработка) ===
# Достаточно скопировать этот файл в .env как есть.
#
# === PROD (на сервере) ===
# Сгенерируй SECRET_KEY:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# и подставь сюда. Также пропиши свой ALLOWED_HOSTS и CSRF_TRUSTED_ORIGINS.

# Секретный ключ Django. На prod обязательно сгенерировать новый.
DJANGO_SECRET_KEY=django-insecure-CHANGE-ME

# DEBUG=True для dev, DEBUG=False для prod.
DJANGO_DEBUG=True

# Через запятую. На prod — IP/домен сервера.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Для AJAX (catalog_save_from_form) на prod. На dev не используется.
# Формат: схема://хост, через запятую.
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1
